<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".seller_information">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/yeallw_top">



        <ImageView
            android:layout_width="@dimen/_70sdp"
            android:layout_height="@dimen/_70sdp"
            android:layout_marginLeft="@dimen/_30sdp"
            android:layout_marginTop="10dp"
            android:src="@drawable/logo_bird" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_95sdp"
            android:layout_marginTop="@dimen/_28sdp"
            android:fontFamily="@font/miltonian_tattoo"
            android:shadowColor="#2196F3"
            android:shadowDx="4"
            android:shadowDy="4"
            android:shadowRadius="10"
            android:text="You &amp; Me Seller"
            android:textColor="@color/white"
            android:textSize="@dimen/_22ssp" />

    </RelativeLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/_85sdp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">


                <LinearLayout
                    android:id="@+id/progress_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:orientation="horizontal">


                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal">


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/circle_vector"
                                android:fontFamily="@font/dm_serif_display"
                                android:gravity="center"
                                android:text="1"
                                android:textColor="@color/black"
                                android:textSize="@dimen/_14ssp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:background="#DB8304" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/circle_vector"
                                android:fontFamily="@font/dm_serif_display"
                                android:gravity="center"
                                android:text="2"
                                android:textColor="@color/black"
                                android:textSize="@dimen/_14ssp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:background="#DB8304" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/circle_vector"
                                android:fontFamily="@font/dm_serif_display"
                                android:gravity="center"
                                android:text="3"
                                android:textColor="@color/black"
                                android:textSize="@dimen/_14ssp"
                                android:textStyle="bold" />


                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="1dp"
                                android:layout_gravity="center_vertical"
                                android:background="#A5AAA6" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/circle_vector"
                                android:backgroundTint="#D0CECE"
                                android:fontFamily="@font/dm_serif_display"
                                android:gravity="center"
                                android:text="4"
                                android:textColor="@color/black"
                                android:textSize="@dimen/_14ssp"
                                android:textStyle="bold" />


                        </LinearLayout>

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">


                            <ProgressBar
                                android:id="@+id/progressbar_seller_info"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:indeterminateOnly="false"
                                android:progressDrawable="@drawable/circular" />

                            <TextView
                                android:id="@+id/text_percentage_seller_info"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:fontFamily="@font/caudex"
                                android:text="0%"
                                android:textColor="@color/black"
                                android:textSize="18sp"
                                android:textStyle="bold" />


                        </RelativeLayout>


                    </LinearLayout>

                </LinearLayout>




            </RelativeLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/_28sdp"
                android:fontFamily="@font/chonburi"
                android:shadowColor="#8BC34A"
                android:shadowDx="4"
                android:shadowDy="4"
                android:shadowRadius="10"
                android:text="Seller Information"
                android:textColor="@color/black"
                android:textSize="@dimen/_22ssp" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_19sdp"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/caudex"
                android:text="Seller Name"
                android:textStyle="bold"

                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp" />


            <EditText
                android:id="@+id/seller_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:background="@drawable/edittext_touch_effect"
                android:fontFamily="@font/caudex"
                android:hint="Seller Full Name"
                android:inputType="text"
                android:padding="17dp"
                android:paddingStart="10dp"
                android:paddingEnd="@dimen/_8sdp"
                android:textColor="@color/black"
                android:textColorHint="#AEADAC"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textSize="18sp" />



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_19sdp"
                android:layout_marginTop="25dp"
                android:fontFamily="@font/caudex"
                android:textStyle="bold"

                android:text="Set a name for your 'UpTrend Store'"
                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp" />


            <EditText
                android:id="@+id/store_name_seller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:background="@drawable/edittext_touch_effect"
                android:fontFamily="@font/caudex"
                android:hint="Enter Display Name"
                android:inputType="text"
                android:padding="17dp"
                android:paddingStart="10dp"
                android:paddingEnd="@dimen/_8sdp"
                android:textColor="@color/black"
                android:textColorHint="#AEADAC"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textSize="18sp" />



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_19sdp"
                android:layout_marginTop="25dp"
                android:fontFamily="@font/caudex"
                android:text="Pickup Pincode"
                android:textStyle="bold"

                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp" />


            <EditText
                android:id="@+id/pincode_seller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:background="@drawable/edittext_touch_effect"
                android:fontFamily="@font/caudex"
                android:hint="Enter Pickup Pincode"
                android:imeOptions="actionDone"
                android:inputType="number"
                android:maxLength="6"
                android:padding="17dp"
                android:paddingStart="10dp"
                android:paddingEnd="@dimen/_8sdp"
                android:textColor="@color/black"
                android:textColorHint="#AEADAC"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textSize="18sp" />


            <TextView
                android:id="@+id/pincode_msg"

                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_19sdp"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/caudex"
                android:textStyle="bold"
                android:textColor="#F43E05"
                android:textSize="@dimen/_12ssp" />



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_19sdp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/caudex"
                android:text="Store Address Details"
                android:textStyle="bold"

                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp" />


            <EditText
                android:id="@+id/address1_seller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:background="@drawable/edittext_touch_effect"
                android:fontFamily="@font/caudex"
                android:hint="Shop No, Building Name, Floor"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:padding="40dp"
                android:paddingStart="10dp"
                android:paddingEnd="@dimen/_8sdp"
                android:textColor="@color/black"
                android:textColorHint="#AEADAC"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textSize="18sp" />


            <EditText
                android:id="@+id/address2_seller"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:background="@drawable/edittext_touch_effect"
                android:fontFamily="@font/caudex"
                android:layout_marginTop="13dp"
                android:hint="Road Name, Area, Colony"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:padding="40dp"
                android:paddingStart="10dp"
                android:paddingEnd="@dimen/_8sdp"
                android:textColor="@color/black"
                android:textColorHint="#AEADAC"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textSize="18sp" />



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:fontFamily="@font/caudex"
                android:text="Select State"
                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp"
                android:textStyle="bold" />


            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.FilledBox.Dense.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:textColorHint="#024805"
                app:boxCornerRadiusBottomEnd="@dimen/_10sdp"
                app:boxCornerRadiusBottomStart="@dimen/_10sdp"
                app:boxCornerRadiusTopEnd="@dimen/_10sdp"
                app:boxCornerRadiusTopStart="@dimen/_10sdp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:endIconMode="dropdown_menu"
                app:endIconTint="#024805"
                app:hintTextColor="#024805">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/txtState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#8023AE27"
                    android:fontFamily="@font/caudex"
                    android:hint="Select state"
                    android:inputType="none"
                    android:popupBackground="#FFFFFF"
                    android:textColor="@color/black"
                    android:textColorHighlight="@color/black"
                    android:textSize="@dimen/_13sdp"
                    android:textStyle="bold" />

            </com.google.android.material.textfield.TextInputLayout>



            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_marginTop="@dimen/_15sdp"
                android:fontFamily="@font/caudex"
                android:text="Select City"
                android:textColor="@color/black"
                android:textSize="@dimen/_12ssp"
                android:textStyle="bold" />


            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.FilledBox.Dense.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_15sdp"
                android:layout_marginEnd="@dimen/_15sdp"
                android:textColorHint="#024805"
                app:boxCornerRadiusBottomEnd="@dimen/_10sdp"
                app:boxCornerRadiusBottomStart="@dimen/_10sdp"
                app:boxCornerRadiusTopEnd="@dimen/_10sdp"
                app:boxCornerRadiusTopStart="@dimen/_10sdp"
                app:boxStrokeWidth="0dp"
                app:boxStrokeWidthFocused="0dp"
                app:endIconMode="dropdown_menu"
                app:endIconTint="#024805"
                app:hintTextColor="#024805">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/txtCity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="#8023AE27"
                    android:fontFamily="@font/caudex"
                    android:hint="Select city"
                    android:inputType="none"
                    android:popupBackground="#FFFFFF"
                    android:textColor="@color/black"
                    android:textColorHighlight="@color/black"
                    android:textSize="@dimen/_13sdp"
                    android:textStyle="bold" />

            </com.google.android.material.textfield.TextInputLayout>







            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_seller_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_40sdp"
                android:layout_marginEnd="@dimen/_40sdp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="40dp"
                android:background="@drawable/button_background"
                android:fontFamily="@font/caudex"
                android:text="next"
                android:textColor="@color/white"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold" />

        </LinearLayout>


    </ScrollView>


</RelativeLayout>