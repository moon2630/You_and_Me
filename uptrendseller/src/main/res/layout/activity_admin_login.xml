<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".admin_login">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/yeallw_top">



        <ImageView
            android:layout_width="@dimen/_70sdp"
            android:layout_height="@dimen/_70sdp"
            android:layout_marginLeft="@dimen/_30sdp"
            android:layout_marginTop="10dp"
            android:src="@drawable/logo_bird" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_95sdp"
            android:layout_marginTop="@dimen/_28sdp"
            android:fontFamily="@font/miltonian_tattoo"
            android:shadowColor="#2196F3"
            android:shadowDx="4"
            android:shadowDy="4"
            android:shadowRadius="10"
            android:text="You &amp; Me Seller"
            android:textColor="@color/white"
            android:textSize="@dimen/_22ssp" />

    </RelativeLayout>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/_85sdp">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">





            <TextView
                android:id="@+id/marquee_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:ellipsize="marquee"
                android:fontFamily="@font/caudex"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:shadowColor="#23A528"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="1"
                android:singleLine="true"
                android:text="          Welcome to UpTrend Seller! Please You can Log in and Sign up your account.."
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold" />


            <TextView
                android:id="@+id/signUp_txt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/chonburi"
                android:text="Sign Up"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="55dp"
                android:textColor="#06AC0D"
                android:layout_below="@id/marquee_text"
                android:textSize="22sp"
                android:textStyle="bold" />


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="440dp"
                android:layout_below="@+id/marquee_text"
                android:layout_marginTop="@dimen/_20sdp"
                android:layout_marginEnd="180dp"
                android:layout_marginBottom="5dp"
                app:cardBackgroundColor="#1D9022"
                app:cardCornerRadius="10dp"
                app:cardElevation="8dp">


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="65dp"
                    android:fontFamily="@font/chonburi"
                    android:text="Log in"
                    android:textColor="@color/white"
                    android:layout_below="@id/marquee_text"
                    android:textSize="22sp"
                    android:textStyle="bold" />




            </androidx.cardview.widget.CardView>


            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/marquee_text"
                android:layout_marginStart="10dp"
                android:layout_marginTop="@dimen/_70sdp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="8dp">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/email_login"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="@dimen/_30sdp"
                        android:layout_marginEnd="18dp"
                        android:background="@drawable/edittext_touch_effect"
                        android:drawableStart="@drawable/email_vector_effect"
                        android:drawablePadding="@dimen/_10sdp"
                        android:fontFamily="@font/caudex"
                        android:hint="email"
                        android:inputType="text"
                        android:padding="@dimen/_12sdp"
                        android:paddingStart="10dp"
                        android:paddingEnd="@dimen/_8sdp"
                        android:textColor="@color/black"
                        android:textColorHint="#717069"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="18sp" />


                    <TextView
                        android:id="@+id/forget_password"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="200dp"
                        android:layout_marginTop="5dp"
                        android:fontFamily="@font/caudex"
                        android:text="forget password"
                        android:textColor="#0E9C14"
                        android:textSize="16sp"
                        android:textStyle="bold" />


                    <EditText
                        android:id="@+id/password_login"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="18dp"
                        android:layout_marginTop="@dimen/_16sdp"
                        android:layout_marginEnd="18dp"
                        android:background="@drawable/edittext_touch_effect"
                        android:drawableStart="@drawable/lock_vector_effect"
                        android:drawablePadding="@dimen/_10sdp"
                        android:fontFamily="@font/caudex"
                        android:hint="Password"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:padding="@dimen/_11sdp"
                        android:paddingStart="10dp"
                        android:paddingEnd="@dimen/_8sdp"
                        android:textColor="@color/black"
                        android:textColorHint="#717069"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="18sp" />


                    <CheckBox
                        android:id="@+id/checkbox_signin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:layout_marginStart="20dp"
                        android:button="@drawable/checkbox_selector"
                        android:fontFamily="@font/caudex"
                        android:text="show password"
                        android:textSize="16sp"
                        android:theme="@style/CustomCheckBox" />


                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btn_login_admin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_60sdp"
                        android:layout_marginTop="@dimen/_25sdp"
                        android:layout_marginEnd="@dimen/_60sdp"
                        android:background="@drawable/button_background"
                        android:fontFamily="@font/caudex"
                        android:padding="10dp"
                        android:text="log in"
android:textColor="@color/white"
                        android:textSize="@dimen/_16ssp"
                        android:textStyle="bold"
                        android:layout_marginBottom="30dp"/>





                </LinearLayout>


            </androidx.cardview.widget.CardView>


        </RelativeLayout>


    </ScrollView>


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_alignParentBottom="true">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_27sdp"
            android:fontFamily="@font/caudex"
            android:textColor="#A09E9E"
            android:text="Don't have an account?"
            android:textSize="@dimen/_14ssp" />

        <TextView
            android:id="@+id/new_account_txt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_190sdp"
            android:fontFamily="@font/caudex"
            android:text="SIGN UP"
            android:textColor="@color/black"
            android:textSize="@dimen/_16ssp"
            android:textStyle="bold" />

    </RelativeLayout>


</RelativeLayout>