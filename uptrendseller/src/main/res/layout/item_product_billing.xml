<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="5dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Product Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Product Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:fontFamily="@font/caudex" />

                <TextView
                    android:id="@+id/txtCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Category"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:fontFamily="@font/caudex" />

                <TextView
                    android:id="@+id/txtProductId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: BE-123456"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/caudex" />
            </LinearLayout>



            <TextView
                android:id="@+id/txtEarnings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="₹0"
                android:textSize="16sp"
                android:textColor="#0B7810"
                android:textStyle="bold"
                android:gravity="end"
                android:fontFamily="@font/caudex" />
        </LinearLayout>

        <!-- Price Details Row - Add android:id for detailsLayout -->
        <LinearLayout
            android:id="@+id/detailsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:background="#E7F2F8"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtOriginalPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Original: ₹0"
                android:textSize="14sp"
                android:textColor="#666161"
                android:fontFamily="@font/caudex" />

            <TextView
                android:id="@+id/txtSellingPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Selling: ₹0"
                android:textSize="14sp"
                android:textColor="#666161"
                android:gravity="center"
                android:fontFamily="@font/caudex" />

            <TextView
                android:id="@+id/txtCommission"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Comm: ₹0555555"
                android:textSize="14sp"
                android:textColor="#D32F2F"
                android:gravity="end"
                android:fontFamily="@font/caudex" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" + 30 PF"
                android:textSize="14sp"
                android:textColor="#D32F2F"
                android:gravity="end"
                android:fontFamily="@font/caudex" />
        </LinearLayout>

        <!-- Expand Button -->
        <TextView
            android:id="@+id/btnExpand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Show Details"
            android:textSize="15sp"
            android:textColor="@color/blue"
            android:gravity="center"
            android:padding="2dp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/caudex" />

    </LinearLayout>
</androidx.cardview.widget.CardView>