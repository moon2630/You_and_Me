<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/green_meee"
        android:padding="16dp">


        <TextView
            android:id="@+id/back30"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Back"
            android:drawableStart="@drawable/arrow_vector"
            android:drawableTint="@color/white"
            android:textSize="18sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:layout_marginBottom="5dp"
            android:fontFamily="@font/caudex" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="5dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ALL PRODUCTS BILLING REPORT"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="5dp"
            android:fontFamily="@font/caudex" />

        <TextView
            android:id="@+id/txtReportDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date: Loading..."
            android:textSize="14sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:fontFamily="@font/caudex" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginTop="5dp" />
    </LinearLayout>

    <!-- Summary Cards -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#EBFAEB">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtTotalProducts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textColor="@color/blue"
                    android:textStyle="bold"
                    android:fontFamily="@font/caudex" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Products"
                    android:textSize="12sp"
                    android:textColor="#5C5A5A"
                    android:fontFamily="@font/caudex" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#E0E0E0" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtTotalEarnings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="24sp"
                    android:textColor="#388E3C"
                    android:textStyle="bold"
                    android:fontFamily="@font/caudex" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Earnings"
                    android:textSize="12sp"
                    android:textColor="#5C5A5A"
                    android:fontFamily="@font/caudex" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="40dp"
                android:background="#E0E0E0" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/txtTotalCommission"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₹0"
                    android:textSize="24sp"
                    android:textColor="#D32F2F"
                    android:textStyle="bold"
                    android:fontFamily="@font/caudex" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Commission"
                    android:textSize="12sp"
                    android:textColor="#5C5A5A"
                    android:fontFamily="@font/caudex" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Product List Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F5F5F5"
        android:padding="12dp"
        android:layout_marginLeft="16dp"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Product"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:fontFamily="@font/caudex" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Category"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:fontFamily="@font/caudex" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Earnings"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="end"
            android:fontFamily="@font/caudex" />
    </LinearLayout>

    <!-- Product List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewProducts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
        android:layout_marginBottom="16dp"
        android:fadingEdgeLength="20dp"
        android:paddingVertical="4dp"
        android:nestedScrollingEnabled="true"
        android:scrollbars="vertical"
        android:fadeScrollbars="false"
        android:overScrollMode="always"
        android:clipToPadding="false"
        android:requiresFadingEdge="vertical"
        />


    <!-- Loading/Empty State -->
    <TextView
        android:id="@+id/txtEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No products found. Add products to see billing details."
        android:textSize="16sp"
        android:textColor="#666666"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"
        android:fontFamily="@font/caudex" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="32dp"
        android:indeterminateTint="#13A319"

        android:visibility="gone" />

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F5F5F5"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtFooterNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Earnings are calculated based on selling price minus commission and platform fees."
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:fontFamily="@font/caudex" />
    </LinearLayout>

</LinearLayout>