<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".signUp_and_logIn_page">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/yeallw_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="@dimen/_75sdp"
            android:layout_height="@dimen/_75sdp"
            android:layout_marginLeft="@dimen/_49sdp"
            android:layout_marginTop="10dp"
            android:src="@drawable/vector_bird_logo5" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/_128sdp"
            android:layout_marginTop="@dimen/_28sdp"
            android:fontFamily="@font/miltonian_tattoo"
            android:shadowColor="#8BC34A"
            android:shadowDx="5"
            android:shadowDy="5"
            android:shadowRadius="5"
            android:text="You &amp; Me"
            android:textColor="@color/white"
            android:textSize="@dimen/_24ssp" />

    </RelativeLayout>

    <ScrollView
        android:id="@+id/scrollView3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/_85sdp"
        app:layout_constraintBottom_toBottomOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
           >


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:fontFamily="@font/dm_serif_display"
                android:text="@string/welcome"
                android:textColor="@color/black"
                android:textSize="@dimen/_40ssp" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="65dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:layout_marginEnd="@dimen/_10sdp"
                    app:cardElevation="7dp"
                    android:layout_marginBottom="10dp"

                    app:cardCornerRadius="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/white"
                        android:gravity="center"

                        android:orientation="vertical">


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"

                            android:padding="@dimen/_5sdp">

                            <RadioButton
                                android:id="@+id/radioBtn_create_account"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:theme="@style/MyRadioButton" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_2sdp"
                                android:fontFamily="@font/caudex"
                                android:text="@string/createAc"
                                android:textColor="@color/black"
                                android:textSize="@dimen/_16ssp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_10sdp"
                                android:layout_marginTop="@dimen/_2sdp"
                                android:fontFamily="@font/caudex"
                                android:text="@string/newAcm"

                                android:textColor="@color/black"
                                android:textSize="@dimen/_15ssp" />
                        </LinearLayout>


                        <LinearLayout
                            android:id="@+id/layout_hide_show_create_account"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/cardview_effect"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <EditText
                                android:id="@+id/name_create_account"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/edittext_touch_effect"
                                android:drawableStart="@drawable/person_vector_effect"

                                android:drawablePadding="@dimen/_10sdp"
                                android:fontFamily="@font/caudex"
                                android:hint="@string/firstLastName"
                                android:imeOptions="actionDone"
                                android:inputType="text"
                                android:padding="@dimen/_15sdp"
                                android:paddingStart="10dp"
                                android:paddingEnd="@dimen/_8sdp"
                                android:textColor="@color/black"
                                android:textColorHint="#717069"
                                android:textCursorDrawable="@drawable/cursor_color"
                                android:textSize="18sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_9sdp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="50dp"
                                    android:layout_height="45dp"
                                    android:layout_marginLeft="@dimen/_5sdp"
                                    android:layout_marginTop="6dp"
                                    android:fontFamily="@font/brygada_1918"
                                    android:gravity="center"
                                    android:text="+91"
                                    android:textAlignment="center"
                                    android:textColor="@color/black"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <EditText
                                    android:id="@+id/mobileno_create_account"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="5dp"
                                    android:layout_marginLeft="10dp"
                                    android:layout_marginTop="7dp"
                                    android:layout_marginEnd="10dp"
                                    android:background="@drawable/edittext_touch_effect"
                                    android:drawableStart="@drawable/phone_vector_effect"
                                    android:drawablePadding="@dimen/_10sdp"
                                    android:fontFamily="@font/caudex"
                                    android:hint="@string/mobileNo"
                                    android:imeOptions="actionDone"
                                    android:inputType="number"
                                    android:maxLength="10"

                                    android:padding="@dimen/_15sdp"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="@dimen/_8sdp"
                                    android:textColor="@color/black"
                                    android:textColorHint="#717069"
                                    android:textCursorDrawable="@drawable/cursor_color"
                                    android:textSize="18sp" />


                            </LinearLayout>


                            <EditText
                                android:id="@+id/email_create_account"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginTop="@dimen/_16sdp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/edittext_touch_effect"
                                android:drawableStart="@drawable/email_vector_effect"
                                android:drawablePadding="@dimen/_10sdp"
                                android:fontFamily="@font/caudex"
                                android:hint="@string/email"
                                android:imeOptions="actionDone"
                                android:inputType="text"

                                android:padding="@dimen/_15sdp"
                                android:paddingStart="10dp"
                                android:paddingEnd="@dimen/_8sdp"
                                android:textColor="@color/black"
                                android:textColorHint="#717069"
                                android:textCursorDrawable="@drawable/cursor_color"
                                android:textSize="18sp" />


                            <EditText
                                android:id="@+id/password_create_account"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginTop="@dimen/_15sdp"
                                android:layout_marginEnd="10dp"
                                android:background="@drawable/edittext_touch_effect"
                                android:drawableStart="@drawable/lock_vector_effect"
                                android:drawablePadding="@dimen/_10sdp"
                                android:fontFamily="@font/caudex"
                                android:hint="@string/password"
                                android:imeOptions="actionDone"
                                android:inputType="textPassword"
                                android:padding="@dimen/_15sdp"
                                android:paddingStart="10dp"
                                android:paddingEnd="@dimen/_8sdp"
                                android:textColor="@color/black"
                                android:textColorHint="#717069"
                                android:textCursorDrawable="@drawable/cursor_color"

                                android:textSize="18sp" />


                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/_20sdp"
                                android:fontFamily="@font/caudex"
                                android:text="@string/passwordMsg"
                                android:textColor="#098E0E"
                                android:textSize="@dimen/_11ssp" />

                            <CheckBox
                                android:id="@+id/checkbox_create_account"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:layout_marginEnd="@dimen/_60sdp"
                                android:button="@drawable/checkbox_selector"
                                android:fontFamily="@font/caudex"
                                android:text="@string/showPass"
                                android:textSize="16sp"
                                android:theme="@style/CustomCheckBox" />


                            <androidx.appcompat.widget.AppCompatButton
                                android:id="@+id/create_account"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/_15sdp"
                                android:layout_marginTop="@dimen/_25sdp"
                                android:layout_marginEnd="@dimen/_15sdp"
                                android:background="@drawable/button_background"
                                android:fontFamily="@font/caudex"
                                android:padding="10dp"
                                android:text="@string/createAc"

                                android:textColor="@color/white"
                                android:textSize="@dimen/_16ssp"
                                android:textStyle="bold" />


                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_horizontal"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/_10sdp"
                                    android:fontFamily="@font/caudex"
                                    android:text="By creating an account or logging in, you agree to"
                                    android:textColor="@color/black"
                                    android:textSize="@dimen/_11ssp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center_horizontal"
                                    android:orientation="horizontal">


                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/caudex"
                                        android:text="UpTrend's"
                                        android:textColor="@color/black"
                                        android:textSize="@dimen/_11ssp" />

                                    <TextView
                                        android:id="@+id/terms_CA"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="7dp"
                                        android:fontFamily="@font/caudex"
                                        android:text="Conditions of Use"
                                        android:textColor="#082DFB"
                                        android:textSize="@dimen/_11ssp"
                                        android:textStyle="bold" />


                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="5dp"
                                        android:fontFamily="@font/caudex"
                                        android:text="and"
                                        android:textColor="@color/black"

                                        android:textSize="@dimen/_11ssp" />


                                    <TextView
                                        android:id="@+id/privacy_policy_CA"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginStart="7dp"
                                        android:fontFamily="@font/caudex"
                                        android:text="Privacy Policy."
                                        android:textColor="#082DFB"

                                        android:textSize="@dimen/_11ssp"
                                        android:textStyle="bold" />

                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                           >


                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="@dimen/_5sdp">


                                <RadioButton
                                    android:id="@+id/radioBtn_signIn"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:theme="@style/MyRadioButton" />


                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/_2sdp"
                                    android:fontFamily="@font/caudex"
                                    android:text="@string/signIn2"
                                    android:textColor="@color/black"

                                    android:textSize="@dimen/_16ssp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/_10sdp"
                                    android:layout_marginTop="@dimen/_2sdp"
                                    android:fontFamily="@font/caudex"
                                    android:text="@string/already2"

                                    android:textColor="@color/black"
                                    android:textSize="@dimen/_15ssp" />


                            </LinearLayout>


                            <LinearLayout
                                android:id="@+id/layout_hide_show_signin"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@drawable/cardview_effect"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:visibility="gone">


                                <EditText
                                    android:id="@+id/email_signin"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:layout_marginTop="@dimen/_16sdp"
                                    android:layout_marginEnd="10dp"
                                    android:background="@drawable/edittext_touch_effect"
                                    android:drawableStart="@drawable/email_vector_effect"
                                    android:drawablePadding="@dimen/_10sdp"
                                    android:fontFamily="@font/caudex"
                                    android:hint="@string/email"
                                    android:inputType="text"
                                    android:padding="@dimen/_15sdp"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="@dimen/_8sdp"
                                    android:textColor="@color/black"
                                    android:textColorHint="#717069"
                                    android:textCursorDrawable="@drawable/cursor_color"
                                    android:textSize="18sp" />

                                <EditText
                                    android:id="@+id/password_signin"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="10dp"
                                    android:layout_marginTop="@dimen/_16sdp"
                                    android:layout_marginEnd="10dp"
                                    android:background="@drawable/edittext_touch_effect"
                                    android:drawableStart="@drawable/lock_vector_effect"
                                    android:drawablePadding="@dimen/_10sdp"
                                    android:fontFamily="@font/caudex"
                                    android:hint="@string/password"
                                    android:imeOptions="actionDone"
                                    android:inputType="textPassword"

                                    android:padding="@dimen/_15sdp"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="@dimen/_8sdp"
                                    android:textColor="@color/black"
                                    android:textColorHint="#717069"
                                    android:textCursorDrawable="@drawable/cursor_color"
                                    android:textSize="18sp" />


                                <TextView
                                    android:id="@+id/txtForgotPassword"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="80dp"
                                    android:fontFamily="@font/caudex"
                                    android:text="@string/forget"
                                    android:textColor="#09A30F"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />


                                <CheckBox
                                    android:id="@+id/checkbox_signin"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="5dp"
                                    android:layout_marginEnd="@dimen/_60sdp"
                                    android:button="@drawable/checkbox_selector"
                                    android:fontFamily="@font/caudex"
                                    android:text="@string/showPass"
                                    android:textSize="16sp"
                                    android:theme="@style/CustomCheckBox" />


                                <androidx.appcompat.widget.AppCompatButton
                                    android:id="@+id/sign_in"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="@dimen/_15sdp"
                                    android:layout_marginTop="@dimen/_25sdp"
                                    android:layout_marginEnd="@dimen/_15sdp"
                                    android:background="@drawable/button_background"
                                    android:fontFamily="@font/caudex"
                                    android:padding="10dp"
                                    android:textColor="@color/white"
                                    android:text="@string/signIn2"
                                    android:textSize="@dimen/_16ssp"
                                    android:textStyle="bold" />


                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:layout_marginBottom="10dp"
                                    android:gravity="center_horizontal"
                                    android:orientation="vertical">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/_10sdp"
                                        android:fontFamily="@font/caudex"
                                        android:text="By continuing you agree to Uptrend's"
                                        android:textColor="@color/black"
                                        android:textSize="@dimen/_11ssp" />


                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:gravity="center_horizontal"
                                        android:orientation="horizontal">


                                        <TextView
                                            android:id="@+id/terms_signIn"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="@font/caudex"
                                            android:text="Conditions of Use"
                                            android:textColor="#082DFB"
                                            android:textSize="@dimen/_11ssp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="5dp"
                                            android:layout_marginEnd="5dp"
                                            android:fontFamily="@font/caudex"
                                            android:text="and"
                                            android:textColor="@color/black"
                                            android:textSize="@dimen/_11ssp" />


                                        <TextView
                                            android:id="@+id/privacy_policy_signIn"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:fontFamily="@font/caudex"
                                            android:text="Privacy Policy."
                                            android:textColor="#082DFB"
                                            android:textSize="@dimen/_11ssp"
                                            android:textStyle="bold" />


                                    </LinearLayout>

                                </LinearLayout>


                            </LinearLayout>

                        </LinearLayout>


                    </LinearLayout>


                </androidx.cardview.widget.CardView>



            </LinearLayout>


        </LinearLayout>


    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>