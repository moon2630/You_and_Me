                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_8sdp"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/caudex"
                            android:text="a. Provide and Improve Services:"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold" />

                        <TextView
                            android:textColor="@color/black"

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_8sdp"
                            android:fontFamily="@font/caudex"
                            android:text="- We use your information to provide and enhance the functionality of the App, including personalized features and content."
                            android:textSize="@dimen/_13ssp" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_8sdp"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/caudex"
                            android:text="b. Communicate with You:"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_14ssp"
                            android:textStyle="bold" />

