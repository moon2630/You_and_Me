<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FFFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Upload Documents"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="@font/caudex"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <!-- Aadhar Card -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aadhar Card"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/caudex"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:layout_marginBottom="30dp"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imgAadhar"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_launcher_background"
                android:scaleType="centerCrop" />

            <Button
                android:id="@+id/btnUploadAadhar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="20dp"
                android:text="Upload"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <!-- Driving License -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driving License"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/caudex"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:layout_marginBottom="30dp"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imgLicense"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_launcher_background"
                android:scaleType="centerCrop" />

            <Button
                android:id="@+id/btnUploadLicense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="20dp"
                android:text="Upload"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <!-- Vehicle RC -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vehicle Registration (RC)"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/caudex"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:orientation="horizontal"
            android:layout_marginBottom="50dp"
            android:background="#FFFFFF"
            android:elevation="6dp"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imgRC"
                android:layout_width="100dp"
                android:layout_height="match_parent"
                android:src="@drawable/ic_launcher_background"
                android:scaleType="centerCrop" />

            <Button
                android:id="@+id/btnUploadRC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="20dp"
                android:text="Upload"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSubmitDocuments"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="SUBMIT DOCUMENTS"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/caudex"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>