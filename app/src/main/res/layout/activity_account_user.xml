<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".account_user">


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@color/greenmeee"
        app:cardElevation="@dimen/_10sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:orientation="horizontal">


            <TextView
                android:id="@+id/close_btn_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_5sdp"
                android:layout_marginTop="6dp"
                android:drawableTint="@color/white"
                android:drawableStart="@drawable/back_left" />


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_10sdp"
                android:layout_marginTop="@dimen/_11sdp"
                android:fontFamily="@font/dm_serif_display"
                android:text="Hey !"
                android:textColor="@color/white"
                android:textSize="@dimen/_18ssp" />


            <TextView
                android:id="@+id/txtUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="@dimen/_11sdp"
                android:fontFamily="@font/dm_serif_display"
                android:text=""
                android:textColor="@color/white"
                android:textSize="@dimen/_18ssp" />


        </LinearLayout>

    </androidx.cardview.widget.CardView>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_45sdp"
        android:orientation="vertical">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_6sdp"
            android:orientation="horizontal">


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/orders_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:background="@drawable/btn_background_black"
                android:drawableStart="@drawable/order_vector24"
                android:fontFamily="@font/dm_serif_display"
                android:padding="@dimen/_10sdp"
                android:text="Orders"
                android:textColor="@color/black"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold" />


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/wishlist_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:background="@drawable/btn_background_black"
                android:drawableStart="@drawable/heart_vector24"
                android:fontFamily="@font/dm_serif_display"
                android:padding="@dimen/_10sdp"
                android:text="Wishlist"
                android:textColor="@color/black"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold" />

        </LinearLayout>


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/notification_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginEnd="140dp"
            android:background="@drawable/btn_background_black"
            android:drawableStart="@drawable/notification_vector24"
            android:fontFamily="@font/dm_serif_display"
            android:padding="@dimen/_10sdp"
            android:text="Notification"
            android:textColor="@color/black"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/profile_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginEnd="185dp"
            android:background="@drawable/btn_background_black"
            android:drawableStart="@drawable/profile_vector24"
            android:fontFamily="@font/dm_serif_display"
            android:padding="@dimen/_10sdp"
            android:text="Profile"
            android:textColor="@color/black"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/rating_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginEnd="105dp"
            android:background="@drawable/btn_background_black"
            android:drawableStart="@drawable/rating_vector24"
            android:fontFamily="@font/dm_serif_display"
            android:padding="@dimen/_10sdp"
            android:text="Rating &amp; Reviews"
            android:textColor="@color/black"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold" />


        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="@dimen/_15sdp"
            android:layout_marginEnd="180dp"
            android:background="@drawable/btn_background_black"
            android:drawableStart="@drawable/log_out_vector24"
            android:fontFamily="@font/dm_serif_display"
            android:padding="@dimen/_10sdp"
            android:text="Log out"
            android:textColor="@color/black"
            android:textSize="@dimen/_14ssp"
            android:textStyle="bold" />


        <LinearLayout
            android:id="@+id/layoutRecentlyProductuser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_15sdp"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/_15sdp"
                android:fontFamily="@font/caudex"
                android:text="Recently Viewed Product"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewRecentlyProductuser"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>

        </LinearLayout>

    </LinearLayout>


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_13sdp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="50dp"
        app:cardElevation="5dp">
    <LinearLayout
        android:id="@+id/bottom_nav_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:background="@drawable/bottom_background"
        android:orientation="horizontal"
        android:padding="8dp">


    <TextView
            android:id="@+id/home3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:layout_weight="1"
            android:clickable="true"
            android:drawableTop="@drawable/home_vector"
            android:drawablePadding="4dp"
            android:drawableTint="#100101"
            android:focusable="true"
            android:fontFamily="@font/caudex"
            android:gravity="center_horizontal"
            android:text="Home"
            android:textColor="#100101"
            android:textSize="12sp"
            />

        <TextView
            android:id="@+id/categories3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:layout_weight="1"
            android:clickable="true"

            android:drawableTop="@drawable/category_vector"
            android:drawablePadding="4dp"
            android:drawableTint="#100101"
            android:focusable="true"
            android:fontFamily="@font/caudex"
            android:gravity="center_horizontal"
            android:text="Categories"
            android:textColor="#100101"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/account3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:layout_weight="1"
            android:clickable="true"
            android:drawableTop="@drawable/vector_account"
            android:drawablePadding="4dp"
            android:drawableTint="#3ABE40"
            android:focusable="true"
            android:fontFamily="@font/caudex"
            android:gravity="center_horizontal"
            android:text="Account"
            android:textColor="#3ABE40"
            android:textStyle="bold"
            android:textSize="13sp" />


        <TextView
            android:id="@+id/bag3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginTop="5dp"
            android:layout_weight="1"
            android:clickable="true"
            android:drawableTop="@drawable/add_to_bag_vector"
            android:drawablePadding="4dp"
            android:drawableTint="#100101"
            android:focusable="true"
            android:fontFamily="@font/caudex"
            android:gravity="center_horizontal"
            android:text="Bag"
            android:textColor="#100101"
            android:textSize="12sp" />


    </LinearLayout>

        <TextView
            android:id="@+id/add_to_cart_notification3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="292dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/circle_vector2"
            android:backgroundTint="#33B938"
            android:fontFamily="@font/dm_serif_display"
            android:text=""
            android:textAlignment="center"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:visibility="gone" />



    </androidx.cardview.widget.CardView>


</RelativeLayout>
