<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.UpTrend" parent="Theme.Material3.DayNight.NoActionBar">



        <item name="android:windowAnimationStyle">@style/CustomActivityAnimation</item>
        <item name="bottomNavigationStyle">@color/white</item>


    </style>


    <style name="MyRadioButton" parent="Theme.AppCompat.Light">
        <item name="colorControlNormal">@color/black</item>
        <item name="colorControlActivated">#12CD1B</item>
    </style>


    <style name="CustomCheckBox" parent="Theme.AppCompat.Light">

    </style>

    <style name="MyRatingBar" parent="@android:style/Widget.RatingBar">
        <item name="android:minHeight">10dp</item>
        <item name="android:maxHeight">10dp</item>
        <item name="colorControlNormal">#676363</item>
        <item name="colorControlActivated">#FFE607</item>
    </style>

    // for SquareImageview
    <style name="ShapeAppearanceOverlay.App.CornerSize10Percent" parent="">
        <item name="cornerSize">10%</item>
    </style>

    //for navigation bar
    <style name="CustomActivityAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
    </style>


    <style name="nevigation_text" parent="android:Widget.TextView">
        <item name="android:fontFamily">@font/brygada_1918</item>
    </style>




    //Toast message style

    <style name="UptrendToast">
        <item name="stTextColor">@color/black</item>
        <item name="stColorBackground">#41C647</item>
        <item name="stFont">@font/caudex</item>
        <item name="stStrokeWidth">1dp</item>
        <item name="stTextSize">@dimen/_13ssp</item>
        <item name="stLength">LONG</item>
        <item name="stStrokeColor">@color/black</item>
        <item name="stIconStart">@drawable/vector_bird_logo4</item>
    </style>

    <style name="Theme.UpTrend" parent="Base.Theme.UpTrend" />
</resources>