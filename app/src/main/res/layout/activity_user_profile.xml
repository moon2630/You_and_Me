<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".user_profile">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="30dp"
            app:cardBackgroundColor="#ABE8AE"
            app:cardCornerRadius="10dp"
            app:cardElevation="5dp">


            <TextView
                android:id="@+id/back_btn33"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_marginTop="20dp"
                android:background="@drawable/vector_back" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/selectImage"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginTop="40dp"
                    android:background="@drawable/vector_profile" />


                <TextView
                    android:id="@+id/txtSelectImage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="40dp"
                    android:fontFamily="@font/caudex"
                    android:text="Change Avatar"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_15ssp"
                    android:textStyle="bold" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Avatar Selection Popup (Initially hidden) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/avatarSelectionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="10dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <!-- Male Avatars Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="15dp"
                    android:fontFamily="@font/caudex"
                    android:text="Male Avatars"
                    android:textColor="#0BB012"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold" />


                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_7sdp"
              >
                    <!-- Male Avatars Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/avatarMan1"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Male Avatar 1"
                            android:src="@drawable/vector_man1" />

                        <ImageView
                            android:id="@+id/avatarMan2"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Male Avatar 2"
                            android:src="@drawable/vector_man2" />

                        <ImageView
                            android:id="@+id/avatarMan3"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Male Avatar 3"
                            android:src="@drawable/vector_man3" />

                        <ImageView
                            android:id="@+id/avatarMan4"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Male Avatar 4"
                            android:src="@drawable/vector_man4" />

                        <ImageView
                            android:id="@+id/avatarMan5"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Male Avatar 5"
                            android:src="@drawable/vector_man5" />

                    </LinearLayout>

                </HorizontalScrollView>


                <!-- Female Avatars Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/caudex"
                    android:text="Female Avatars"
                    android:textColor="#0BB012"
                    android:textSize="@dimen/_14ssp"
                    android:textStyle="bold" />


                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_7sdp"
                 >
                    <!-- Female Avatars Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/avatarWoman1"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Female Avatar 1"
                            android:src="@drawable/vector_women1" />

                        <ImageView
                            android:id="@+id/avatarWoman2"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Female Avatar 2"
                            android:src="@drawable/vector_women2" />

                        <ImageView
                            android:id="@+id/avatarWoman3"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Female Avatar 3"
                            android:src="@drawable/vector_women3" />

                        <ImageView
                            android:id="@+id/avatarWoman4"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Female Avatar 4"
                            android:src="@drawable/vector_women4" />

                        <ImageView
                            android:id="@+id/avatarWoman5"
                            android:layout_width="65dp"
                            android:layout_height="65dp"
                            android:layout_margin="8dp"
                            android:background="@drawable/avatar_bg_selector"
                            android:contentDescription="Female Avatar 5"
                            android:src="@drawable/vector_women5" />

                    </LinearLayout>

                </HorizontalScrollView>


                <!-- Close Button -->
                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnCloseAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginStart="80dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginEnd="80dp"
                    android:layout_marginBottom="28dp"
                    android:background="@drawable/btn_background"
                    android:fontFamily="@font/dm_serif_display"
                    android:text="Close"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_14ssp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/_390sdp"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="30dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="10dp"
                app:cardElevation="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_19sdp"
                        android:layout_marginTop="@dimen/_18sdp"
                        android:fontFamily="@font/caudex"
                        android:text="Full Name"
                        android:textColor="#0B9511"
                        android:textSize="@dimen/_12ssp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/userName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_15sdp"
                        android:layout_marginEnd="@dimen/_15sdp"
                        android:fontFamily="@font/caudex"
                        android:imeOptions="actionDone"
                        android:inputType="text"
                        android:paddingStart="10dp"
                        android:paddingEnd="@dimen/_8sdp"
                        android:textColor="@color/black"
                        android:textCursorDrawable="@drawable/cursor_color"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_19sdp"
                        android:layout_marginTop="15dp"
                        android:fontFamily="@font/caudex"
                        android:text="Mobile number"
                        android:textColor="#0B9511"
                        android:textSize="@dimen/_12ssp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_15sdp"
                            android:fontFamily="@font/dm_serif_display"
                            android:text="+91"
                            android:textColor="@color/black"
                            android:textSize="@dimen/_20ssp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/userMobileNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/_15sdp"
                            android:fontFamily="@font/caudex"
                            android:imeOptions="actionDone"
                            android:inputType="textEmailAddress"
                            android:paddingStart="10dp"
                            android:paddingEnd="@dimen/_8sdp"
                            android:textColor="@color/black"
                            android:textCursorDrawable="@drawable/cursor_color"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_19sdp"
                        android:layout_marginTop="15dp"
                        android:fontFamily="@font/caudex"
                        android:text="Email"
                        android:textColor="#0B9511"
                        android:textSize="@dimen/_12ssp"

                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/userEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/_19sdp"
                        android:fontFamily="@font/caudex"
                        android:paddingEnd="@dimen/_10sdp"
                        android:text=""
                        android:textColor="@color/black"
                        android:textSize="@dimen/_15ssp" />

                    <RadioGroup
                        android:id="@+id/radioGroupGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="20dp"
                        android:paddingStart="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5dp"
                            android:layout_marginTop="15dp"
                            android:fontFamily="@font/caudex"
                            android:text="Gender"
                            android:textColor="#0B9511"
                            android:textSize="@dimen/_12ssp"

                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/radioButtonMale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:drawableStart="@drawable/male_vector"
                            android:drawablePadding="15dp"
                            android:fontFamily="@font/caudex"
                            android:text="Male"
                            android:textColor="@color/black"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:theme="@style/MyRadioButton" />

                        <RadioButton
                            android:id="@+id/radioButtonFemale"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/female_vector"
                            android:drawablePadding="15dp"
                            android:fontFamily="@font/caudex"
                            android:text="Female"
                            android:textColor="@color/black"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:theme="@style/MyRadioButton" />

                    </RadioGroup>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginStart="90dp"
                android:layout_marginEnd="90dp"
                android:background="@drawable/btn_background"
                android:fontFamily="@font/dm_serif_display"
                android:padding="10dp"
                android:text="Save profile"
                android:textColor="@color/white"
                android:textSize="@dimen/_15ssp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>