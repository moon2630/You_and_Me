<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F8FFFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Order Details"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="@font/caudex"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="30dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order #123456"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/caudex" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Out for Delivery"
                    android:textSize="18sp"
                    android:textColor="#FF9800"
                    android:fontFamily="@font/caudex"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvCustomerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rajesh Kumar"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/caudex"
                    android:layout_marginTop="20dp" />

                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+91 98765 43210"
                    android:textSize="18sp"
                    android:fontFamily="@font/caudex" />

                <TextView
                    android:id="@+id/tvAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="123 Main St, Andheri West, Mumbai"
                    android:textSize="16sp"
                    android:fontFamily="@font/caudex"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total: ₹1,299 (COD)"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:fontFamily="@font/caudex"
                    android:layout_marginTop="20dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCall"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="Call Customer"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/caudex"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnNavigate"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Navigate"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/caudex"
                android:backgroundTint="#4CAF50"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <Button
            android:id="@+id/btnDelivered"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"
            android:text="Mark as Delivered"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/caudex"
            android:backgroundTint="#2E7D32"
            android:textColor="@android:color/white" />

    </LinearLayout>
</ScrollView>