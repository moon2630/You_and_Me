<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".search_product">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">




        <ImageView
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_39sdp"
            android:layout_marginLeft="@dimen/_4sdp"
            android:src="@drawable/vector_bird_logo4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_52sdp"
            android:layout_marginTop="@dimen/_9sdp"
            android:fontFamily="@font/miltonian_tattoo"
            android:shadowColor="#009688"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="You &amp; Me"
            android:textColor="@color/black"
            android:textSize="@dimen/_17ssp" />


        <TextView
            android:id="@+id/txtFilter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="7dp"
            android:layout_marginEnd="50dp"
            android:background="@drawable/filter_vector"
            android:drawablePadding="10dp"
            />


    </RelativeLayout>


    <androidx.cardview.widget.CardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/_15sdp"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="@dimen/_15sdp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="@dimen/_7sdp"
        app:cardElevation="@dimen/_5sdp">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/searchView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginEnd="80dp"
                android:background="@color/white"
                android:fontFamily="@font/caudex"
                android:hint="search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:padding="15dp"
                android:paddingStart="20dp"
                android:textColor="@color/black"
                android:textColorHint="#959494"
                android:textCursorDrawable="@drawable/cursor_color"
                android:textSize="@dimen/_17ssp" />


            <TextView
                android:id="@+id/iv_mic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="15dp"
                android:layout_marginEnd="30dp"
                android:background="@drawable/assistant_vector"
                android:backgroundTint="#A6A2A2" />

        </RelativeLayout>


    </androidx.cardview.widget.CardView>




        <LinearLayout
            android:id="@+id/recentSearchContainer"
            android:layout_below="@id/search_card"
android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/caudex"
                android:text="Recent Searches"
                android:layout_marginStart="12dp"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewRecentSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp" />

        </LinearLayout>

    <!-- Search Suggestions -->
    <androidx.cardview.widget.CardView
        android:id="@+id/suggestionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/search_card"
        android:layout_marginStart="15dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="15dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </androidx.cardview.widget.CardView>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSearchProduct"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/recentSearchContainer"
        android:layout_marginTop="10dp"
        android:visibility="gone" />


</RelativeLayout>