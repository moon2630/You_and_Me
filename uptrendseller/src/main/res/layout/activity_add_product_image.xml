<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">


    <RelativeLayout
        android:id="@+id/layout_30"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/blue_top"
        android:orientation="vertical">


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/chonburi"
            android:shadowColor="#D9D8D1"
            android:shadowDx="4"
            android:shadowDy="4"
            android:shadowRadius="10"
            android:text="Add Product Image"
            android:textColor="@color/black"
            android:textSize="@dimen/_22ssp" />


    </RelativeLayout>


    <TextView
        android:id="@+id/back_add_product_image"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/layout_30"
        android:layout_marginTop="@dimen/_5sdp"
        android:background="@drawable/back11_vector"
        android:backgroundTint="#2A8E31"
        android:layout_marginStart="20dp"
        android:fontFamily="@font/caudex"
      />

    <TextView
        android:id="@+id/save_image_txt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/layout_30"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="@dimen/_5sdp"
        android:layout_marginEnd="30dp"
        android:fontFamily="@font/caudex"
        android:text="Save &amp; Next"
        android:textColor="#2A8E31"
        android:textSize="@dimen/_19ssp"
        android:textStyle="bold" />


    <TextView
        android:id="@+id/txtCurrentDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="@dimen/_5sdp"
        android:layout_marginEnd="20dp"
        android:fontFamily="@font/caudex"
        android:text="Date: 26/06/2025"
        android:textColor="@color/white"
        android:textSize="@dimen/_12ssp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_105sdp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_hide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/dm_serif_display"
                android:text="Add Image"
                android:textColor="#2A8E31"
                android:visibility="visible"
                android:textSize="@dimen/_26ssp"
                android:textStyle="bold" />

            <androidx.viewpager2.widget.ViewPager2
                android:layout_marginTop="10dp"
                android:id="@+id/viewPager2"
                android:layout_width="match_parent"
                android:layout_height="500dp"
                android:paddingStart="50dp"
                android:paddingEnd="50dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/selectImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/viewPager2"
                android:layout_marginStart="@dimen/_60sdp"
                android:layout_marginTop="@dimen/_25sdp"
                android:layout_marginEnd="@dimen/_60sdp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/button_background"
                android:fontFamily="@font/caudex"
                android:padding="10dp"
                android:text="Select Image"
                android:textColor="@color/black"
                android:textSize="@dimen/_16ssp"
                android:textStyle="bold" />


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/delete_image"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/viewPager2"
                android:layout_marginStart="@dimen/_60sdp"
                android:layout_marginTop="@dimen/_25sdp"
                android:layout_marginEnd="@dimen/_60sdp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/button_background"
                android:fontFamily="@font/caudex"
                android:padding="10dp"
                android:text="Delete Images"
                android:textColor="@color/black"
                android:textSize="@dimen/_16ssp"
                android:textStyle="bold" />

        </RelativeLayout>

    </ScrollView>


</RelativeLayout>
